# Frontend React/Vite .gitignore

# Dependencies
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml

# Environment variables (SENSITIVE)
.env
.env.local
.env.*.local
.env.production
.env.development

# Build outputs
dist/
dist-ssr/
.vite/
build/
out/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Local env files
*.local
.env.local

# IDE and editor
.vscode/*
!.vscode/extensions.json
.vscode-test
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.sublime-project
*.sublime-workspace

# OS files
Thumbs.db
ehthumbs.db
