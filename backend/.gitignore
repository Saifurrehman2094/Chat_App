# Backend Node.js .gitignore

# Dependencies
node_modules/
package-lock.json
yarn.lock

# Environment variables (SENSITIVE)
.env
.env.local
.env.*.local
.env.production
.env.development

# Build artifacts
dist/
build/
.next/
out/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE
.vscode/
.idea/
*.swp
*.swo
*.sublime-*

# OS
.DS_Store
Thumbs.db

# Runtime
.node_cache/
.pnpm-store/

# Database local files
*.db
*.sqlite
*.sqlite3
