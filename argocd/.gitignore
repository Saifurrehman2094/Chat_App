# ArgoCD .gitignore - GitOps Configuration

# ArgoCD local configuration
argocd-local.yaml
argocd-*.local.yaml
local-argocd-config/

# Secrets and sensitive data
argocd-secrets.yaml
*-secret*.yaml
vault-config/

# kubeconfig files
kubeconfig
.kube/

# IDE/Editor
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Backup files
*.backup
*.bak
*~

# Local testing
test-*.yaml
tmp/
